# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017/medical_research_assistant

# External APIs
PUBMED_BASE_URL=https://eutils.ncbi.nlm.nih.gov/entrez/eutils
OPENALEX_BASE_URL=https://api.openalex.org
CLINICALTRIALS_BASE_URL=https://clinicaltrials.gov/api/v2

# PubMed API Key (optional but recommended for higher rate limits)
PUBMED_API_KEY=your_pubmed_api_key_here

# Email for polite API usage (OpenAlex requirement)
CONTACT_EMAIL=your_email@example.com

# Ollama (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Cache
CACHE_TTL_SECONDS=3600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Retrieval config
MAX_RAW_RESULTS_PER_SOURCE=100
FINAL_PAPERS_COUNT=8
FINAL_TRIALS_COUNT=5
